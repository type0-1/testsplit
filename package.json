{
  "name": "testsplit",
  "version": "0.1.0",
  "description": "Test distribution and scheduling engine for parallel CI/CD pipelines",
  "scripts": {
    "test:unit": "jest --config jest.unit.config.js",
    "test:integration": "jest --config jest.integration.config.js",
    "test:all": "npm run test:unit && npm run test:integration",
    "test": "npm run test:unit",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "build": "tsc && npm run build:frontend",
    "build:frontend": "cd src/frontend && npm ci && npm run build",
    "docker:build": "docker compose build",
    "docker:test": "docker compose run --rm testsplit npm run test:all",
    "docker:shell": "docker compose run --rm testsplit bash",
    "api": "ts-node src/backend/api/server.ts",
    "dashboard": "node scripts/dashboard-dev.js"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@types/jest": "30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "25.0.3",
    "eslint": "^10.0.2",
    "fast-check": "^4.6.0",
    "jest": "30.2.0",
    "jest-junit": "^16.0.0",
    "ts-jest": "29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.0.0",
    "@xmldom/xmldom": "0.9.5",
    "chalk": "^4.1.2",
    "fast-xml-parser": "^5.3.4",
    "fastify": "^5.8.2",
    "js-yaml": "^4.1.1",
    "systeminformation": "^5.31.4",
    "yaml": "^2.8.2"
  }
}
